{
  "name": "mock-bff",
  "version": "0.3.0",
  "description": "Mock BFF server for UI modernization using HAR/OpenAPI + AI fallback",
  "type": "module",
  "bin": {
    "mock-bff": "dist/cli.js"
  },
  "files": [
    "dist",
    "admin/dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:admin": "vite --config admin/vite.config.ts",
    "build": "tsc -p tsconfig.json && npm run build:admin",
    "build:admin": "vite build --config admin/vite.config.ts",
    "start": "node dist/server.js",
    "start:cli": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack:check": "npm pack --dry-run"
  },
  "keywords": [
    "mock",
    "bff",
    "har",
    "openapi",
    "ui-testing"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/passelin/mock-bff.git"
  },
  "homepage": "https://github.com/passelin/mock-bff#readme",
  "bugs": {
    "url": "https://github.com/passelin/mock-bff/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.47",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.0.1",
    "@fastify/static": "^9.0.0",
    "ai": "^6.0.134",
    "ajv": "^8.17.1",
    "fastify": "^5.0.0",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.21",
    "vitest": "^4.1.0"
  }
}
